# 🔒 SEGURIDAD: Archivo de ejemplo para variables de entorno
# Copiar a .env.docker.local y configurar valores reales

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080/api

# Backend (configurar en .env.docker.local, user-secrets, o panel de Render)
# dotnet user-secrets set "Authentication:SecretForKey" "your-jwt-secret-here"
# dotnet user-secrets set "Notion:Secret" "ntn_your-notion-token-here"

# Database (PostgreSQL - Render, Supabase, or Neon)
# DATABASE_URL=Host=your-host.render.com;Database=your_db;Username=your_user;Password=your_pass;Port=5432;SSL Mode=Require;Trust Server Certificate=true

# Notion Integration
# NOTION_SECRET=ntn_your-notion-token-here
# NOTION_DATABASE_ID=your-database-id-here
# NOTION_CIVILIZATIONS_DATABASE_ID=your-id-here
# NOTION_AGES_DATABASE_ID=your-id-here
# NOTION_BATTLES_DATABASE_ID=your-id-here
# NOTION_CHARACTERS_DATABASE_ID=your-id-here

# ⚠️  ADVERTENCIA: Nunca commitear .env.docker.local con valores reales
# .env.docker.local ya está en .gitignore