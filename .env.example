# 🔒 SEGURIDAD: Archivo de ejemplo para variables de entorno
# Copiar a .env.local y configurar valores reales

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080

# Backend (configurar en user-secrets, NO en .env)
# dotnet user-secrets set "Authentication:SecretForKey" "your-jwt-secret-here"
# dotnet user-secrets set "Notion:Secret" "ntn_your-notion-token-here"
# dotnet user-secrets set "Notion:DatabaseId" "your-database-id-here"

# Database (SQLite local - no requiere configuración adicional)
# ConnectionStrings__DefaultConnection=Data Source=../../database/wiki-forgotten-empires.db

# ⚠️  ADVERTENCIA: Nunca commitear .env.local con valores reales
