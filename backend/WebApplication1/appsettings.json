    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*", // 🔒 SEGURIDAD: Permitir todos los hosts en desarrollo (Docker requiere soporte para IPv6 en containers)
